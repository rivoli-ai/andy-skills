# Copy to `.env` in the repo root — Docker Compose reads it automatically (`docker compose up`).
# Mirrors appsettings.json + typical appsettings.Development.json overrides.

# --- Ports & public URLs (SPA + CORS + Skills:PublicBaseUrl) ---
SKILL_WEB_PORT=8080
# Optional explicit origins (defaults include localhost + 127.0.0.1 with SKILL_WEB_PORT)
# CORS_ORIGIN_0=http://localhost:8080
# CORS_ORIGIN_1=http://127.0.0.1:8080
SKILLS_PUBLIC_BASE_URL=http://localhost:8080

# --- Postgres (host map defaults to 5433 in docker-compose.yml; API uses postgres:5432 inside Docker) ---
DB_USER=analyser
DB_PASSWORD=analyser_password
POSTGRES_PORT=5433

# Override full connection string for API (e.g. external DB). When unset, Compose builds:
# Host=postgres;Port=5432;Username=DB_USER;Password=DB_PASSWORD;Database=skillregistry
# SKILL_DB_CONNECTION_STRING=

# --- ASP.NET Core ---
ASPNETCORE_ENVIRONMENT=Production
DISABLE_HTTPS_REDIRECTION=true
ALLOWED_HOSTS=*

# Logging (matches appsettings sections)
LOG_LEVEL_DEFAULT=Information
LOG_LEVEL_MICROSOFT_ASPNETCORE=Warning
LOG_LEVEL_EF=Warning

# --- JWT (Production requires JWT_SECRET ≥ 32 chars) ---
JWT_SECRET=skill-registry-docker-bootstrap-secret-change-me-min-32!!
JWT_ISSUER=SkillRegistry
JWT_AUDIENCE=SkillRegistry
JWT_EXPIRY_HOURS=12

# --- Auth ---
AUTH_REQUIRE_BEARER=false

# --- Azure AD (Frontend OIDC; align redirect URIs in Azure with SKILL_PUBLIC_BASE_URL) ---
AZURE_AD_ENABLED=true
AZURE_AD_TYPE=FrontendOidc
AZURE_AD_AUTHORITY=https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0
AZURE_AD_CLIENT_ID=
AZURE_AD_SPA_CLIENT_ID=
AZURE_AD_TENANT_ID=YOUR_TENANT_ID
AZURE_AD_SCOPES=openid profile email User.Read
AZURE_AD_PROFILE_ENDPOINT=https://graph.microsoft.com/v1.0/me

# --- Duende (optional local IdP; usually off in Docker) ---
DUENDE_ENABLED=false
DUENDE_TYPE=FrontendOidc
DUENDE_AUTHORITY=https://localhost:5001
DUENDE_CLIENT_ID=skill-registry-spa
DUENDE_SPA_CLIENT_ID=skill-registry-spa
DUENDE_SCOPES=openid profile email
DUENDE_PROFILE_ENDPOINT=https://localhost:5001/connect/userinfo
DUENDE_DANGEROUS_ACCEPT_ANY_CERT=false
