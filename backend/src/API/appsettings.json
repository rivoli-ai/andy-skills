{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://127.0.0.1:4200"
    ]
  },
  "Skills": {
    "PublicBaseUrl": "http://localhost:5289"
  },
  "Auth": {
    "RequireBearer": false
  },
  "JWT": {
    "Issuer": "SkillRegistry",
    "Audience": "SkillRegistry",
    "ExpiryHours": 12
  },
  "AuthProviders": {
    "AzureAd": {
      "Enabled": true,
      "Type": "FrontendOidc",
      "Authority": "https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0",
      "ClientId": "",
      "SpaClientId": "",
      "TenantId": "YOUR_TENANT_ID",
      "Scopes": "openid profile email User.Read",
      "ProfileEndpoint": "https://graph.microsoft.com/v1.0/me"
    },
    "Duende": {
      "Enabled": false,
      "Type": "FrontendOidc",
      "Authority": "https://localhost:5001",
      "ClientId": "skill-registry-spa",
      "SpaClientId": "skill-registry-spa",
      "Scopes": "openid profile email",
      "ProfileEndpoint": "https://localhost:5001/connect/userinfo",
      "DangerousAcceptAnyServerCertificate": false
    }
  }
}
